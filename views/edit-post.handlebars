<article>
  <a href="/dashboard"> &larr; Back to dashboard</a>
  <h2>
    Edit Post
  </h2>
  <form class="edit-post-form" data-status-scope>
    <div>
      <label for="post-title">Title</label>
      <input id="post-title" name="post-title" type="text" value="{{post.title}}" required />
      <span>({{format_url post.post_url}})</span>
    </div>
    <fieldset class="tag-picker">
      <legend>Topics</legend>
      <div class="tag-options">
        {{#each tags as |tag|}}
        <label>
          <input type="checkbox" name="tag-ids" value="{{tag.id}}" {{#if tag.selected}}checked{{/if}} />
          <span class="tag-pill {{tag.color_token}}">{{tag.name}}</span>
        </label>
        {{/each}}
      </div>
    </fieldset>
    <div>
      {{post.vote_count}} {{format_plural "point" post.vote_count}} by you on {{format_date post.created_at}}
      |
      <a href="/post/{{post.id}}">{{post.comments.length}} {{format_plural "comment" post.comments.length}}</a>
    </div>
    <button type="submit" data-loading-text="Saving...">Save post</button>
    <button type="button" class="delete-post-btn" data-loading-text="Deleting...">Delete post</button>
    <p class="form-status" data-status role="status" aria-live="polite"></p>
  </form>
</article>

<form class="comment-form" data-status-scope>
  <div>
    <label for="comment-body">Comment</label>
    <textarea id="comment-body" name="comment-body" required></textarea>
  </div>

  <div>
    <button type="submit" data-loading-text="Posting...">Add comment</button>
  </div>
  <p class="form-status" data-status role="status" aria-live="polite"></p>
</form>

{{> comments post.comments}}

<script src="/javascript/edit-post.js"></script>
<script src="/javascript/delete-post.js"></script>
<script src="/javascript/comment.js"></script>
