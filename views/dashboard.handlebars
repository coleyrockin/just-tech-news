<section class="panel-section">
  <h2>Create New Post</h2>

  <form class="new-post-form" data-status-scope>
    <div>
      <label for="post-title">Title</label>
      <input type="text" id="post-title" name="post-title" required />
    </div>
    <div>
      <label for="post-url">Link</label>
      <input type="url" id="post-url" name="post-url" required />
    </div>
    <button type="submit" class="btn" data-loading-text="Publishing...">Create</button>
    <p class="form-status" data-status role="status" aria-live="polite"></p>
  </form>
</section>

{{#if posts.length}}
<section class="panel-section">
  <h2>Your Posts</h2>
  <ol>
    {{#each posts as |post|}}
    <li>
      {{> post-info post}}
      <a href="/dashboard/edit/{{post.id}}" class="edit-link">Edit post</a>
    </li>
    {{/each}}
  </ol>
</section>
{{else}}
<p class="empty-state">You have not created any posts yet.</p>
{{/if}}

<script src="/javascript/add-post.js"></script>
